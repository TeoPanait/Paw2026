@{
    ViewData["Title"] = "Autentificare Necesară";
    var returnUrl = ViewData["ReturnUrl"]?.ToString();
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center bg-light p-5 rounded shadow-sm border">
        <h2 class="mb-4">Acces Restricționat 🔒</h2>
        <p class="text-muted mb-4 lead">
            Pentru a putea adăuga, edita sau șterge articole, trebuie să ai un cont.
        </p>

        <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
            <a asp-controller="Auth" asp-action="Login" asp-route-returnUrl="@returnUrl" 
               class="btn btn-primary px-4 fw-bold shadow-sm">
                Loghează-te (Log In)
            </a>
            <a asp-controller="Auth" asp-action="Register" 
               class="btn btn-outline-success px-4 fw-bold shadow-sm">
                Creează cont nou (Sign In)
            </a>
        </div>
        
        <div class="mt-4 text-center">
             <a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none small">Întoarce-te la pagină principală</a>
        </div>
    </div>
</div>